# India Cities Dashboard — Environment Variables
# Copy this file to .env and fill in your API keys.

# OpenAI API Key (for LLM-powered query engine)
# Sign up at https://platform.openai.com/signup
# Go to https://platform.openai.com/api-keys → Create new secret key
# Used for: AI Query page (natural language questions about cities)
# Optional — falls back to rule-based engine without this
OPENAI_API_KEY=your_openai_api_key_here

# OpenWeatherMap API Key (free tier: 1,000 calls/day)
# Sign up at https://openweathermap.org/api
# Used for: Air Quality Index (AQI) data
# Optional — the app works without this (uses seed data for AQI)
OWM_API_KEY=your_openweathermap_api_key_here

# data.gov.in API Key (free, unlimited)
# Sign up at https://data.gov.in
# Used for: Census data, government datasets (Phase 3B)
# DATA_GOV_API_KEY=your_data_gov_key_here

# GeoNames Username (free: 1,000 calls/hour)
# Sign up at https://www.geonames.org/login
# Used for: City coordinates, elevation (Phase 3B)
# GEONAMES_USER=your_username_here
